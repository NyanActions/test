{
  "General": {
    "OsuSongsDir": "Songs",
    "OsuSkinsDir": "Skins"
  },
  "Skin": {
    "CurrentSkin": "ryanstolefromkevin",
    "UseBeatmapColors": true,
    "UseColorsFromSkin": true,
    "FallbackSkin": "default_fallback",
    "Cursor": {
      "UseSkinCursor": true
    }
  },
  "Recording": {
    "Encoder": "libx264",
    "EncoderOptions": "-crf 21 -g 450",
    "Preset": "faster",
    "FrameWidth": 1920,
    "FrameHeight": 1080,
    "FPS": 60,
    "AudioCodec": "aac",
    "AudioOptions": "-b:a 192k"
  },
  "Cursor": {
    "EnableTrailGlow": false,
    "Colors": {
      "EnableRainbow": false
    }
  },
  "Gameplay": {
    "ShowHitLighting": false,
    "Boundaries": {
      "Enabled": false
    },
    "HitErrorMeter": {
      "Show": true,
      "ShowUnstableRate": true
    },
    "AimErrorMeter": {
      "hudElementPosition": {
        "hudElement": {
          "Show": true
        }
      }
    },
    "KeyOverlay": {
      "Show": true
    },
    "ScoreBoard": {
      "Show": true
    },
    "StrainGraph": {
      "Show": true
    }
  },
  "Playfield": {
    "Logo": {
      "Dim": {
        "Intro": 1
      }
    },
    "SeizureWarning": {
      "Enabled": false
    },
    "Background": {
      "FlashToTheBeat": false,
      "Dim": {
        "Normal": 0.85
      },
      "Parallax": {
        "Amount": 0
      }
    },
    "LoadStoryboards": true,
    "LoadVideos": true
  },
  "Objects": {
    "Sliders": {
      "Snaking": {
        "In": false,
        "Out": false
      }
    },
    "Colors": {
      "Sliders": {
        "Border": {
          "Color": {
            "FlashToTheBeat": false
          }
        },
        "Body": {
          "Color": {
            "FlashToTheBeat": false
          }
        }
      }
    }

  }
}
